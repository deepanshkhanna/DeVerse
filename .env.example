# ============================================
# IBM watsonx.ai Configuration
# ============================================
# Get these from: IBM Cloud Console → watsonx.ai
WATSONX_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_REGION_URL=https://us-south.ml.cloud.ibm.com

# watsonx.ai Model Configuration
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct
WATSONX_MAX_TOKENS=500
WATSONX_TEMPERATURE=0.7
WATSONX_TOP_P=0.9

# ============================================
# watsonx Orchestrate Configuration
# ============================================
# Get these from: watsonx Orchestrate Console
ORCHESTRATE_WEBHOOK_URL=your_orchestrate_webhook_url_here
ORCHESTRATE_API_KEY=your_orchestrate_api_key_here
ORCHESTRATE_WORKSPACE_ID=your_workspace_id_here

# ============================================
# Slack Integration (Optional)
# ============================================
# Get these from: Slack API Dashboard
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL_ID=C01234ABCDE
SLACK_ENABLED=false

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ============================================
# Security Settings
# ============================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000