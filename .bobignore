# ============================================
# CRITICAL: Environment Variables & Secrets
# ============================================
# Prevent Bob from reading any credentials
.env
.env.*
**/.env
**/.env.*
*.env

# ============================================
# Credentials & API Keys
# ============================================
**/credentials.json
**/secrets.json
**/*-key.json
**/*-credentials.json
**/*.pem
**/*.key
**/*.cert
**/api-keys.txt
**/tokens.txt

# ============================================
# Node Modules (Performance Optimization)
# ============================================
# Bob doesn't need to read dependencies
node_modules/
**/node_modules/
package-lock.json
yarn.lock

# ============================================
# Build Artifacts
# ============================================
dist/
build/
coverage/
.nyc_output/

# ============================================
# IDE Configuration
# ============================================
.vscode/
.idea/
*.swp
*.swo

# ============================================
# Logs (May Contain Sensitive Data)
# ============================================
*.log
logs/
**/*.log
npm-debug.log*
yarn-debug.log*

# ============================================
# Temporary Files
# ============================================
tmp/
temp/
*.tmp
*.bak
*.cache

# ============================================
# IBM Cloud Files
# ============================================
.bluemix/
.ibmcloud/

# ============================================
# Git Internal Files
# ============================================
.git/
.gitignore

# Made with Bob
